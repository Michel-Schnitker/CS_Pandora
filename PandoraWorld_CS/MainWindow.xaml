<Window x:Class="PandoraWorld_CS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PandoraWorld_CS"
        mc:Ignorable="d"
        Title="Pandora World" Height="800" Width="1000"
        Background="{StaticResource PrimaryBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Obere Leiste mit Zierrahmen -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" 
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,3"
                Effect="{StaticResource TopPanelShadow}">
            <Grid>
                
                <TextBlock Text="🌍 Pandora World" 
                           Foreground="{StaticResource SecondaryBrush}"
                           FontSize="22" 
                           FontWeight="Bold"
                           FontStyle="Italic"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,15,0">
                    <!-- Status mit Rahmen -->
                    <Border BorderBrush="{StaticResource BorderBrush}" 
                            BorderThickness="2" 
                            CornerRadius="10" 
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusIndicator" 
                                     Width="14" Height="14" 
                                     Fill="{StaticResource BoardRed}"/>
                            <TextBlock Text="Status" 
                                       Foreground="{StaticResource SecondaryBrush}"
                                       FontSize="11" Margin="6,0,0,0" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Linkes Menü mit Zierrahmen -->
        <Border Grid.Row="1" Grid.Column="0" 
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,3,0"
                Effect="{StaticResource LeftPanelShadow}">
            <StackPanel Orientation="Vertical" VerticalAlignment="Top" Margin="0,10,0,0">
                
                                
                <Button x:Name="BtnStatistics" 
                        Style="{StaticResource MenuButtonStyle}"
                        Width="50" Height="50" 
                        Margin="5"
                        ToolTip="Statistik"
                        Click="BtnStatistics_Click">
                    <TextBlock Text="📊" FontSize="24"/>
                </Button>
                
                <!-- Kleine Zierleiste zwischen Buttons -->
                <Rectangle Height="1" Width="30" Fill="{StaticResource BorderBrush}" Margin="0,3"/>
                
                <Button x:Name="BtnSettings" 
                        Style="{StaticResource MenuButtonStyle}"
                        Width="50" Height="50" 
                        Margin="5" 
                        ToolTip="Einstellungen"
                        Click="BtnSettings_Click">
                    <TextBlock Text="🔧" FontSize="24"/>
                </Button>
                
                <Rectangle Height="1" Width="30" Fill="{StaticResource BorderBrush}" Margin="0,3"/>

                <Button x:Name="BtnGameBoard" 
                        Style="{StaticResource MenuButtonStyle}"
                        Width="50" Height="50" 
                        Margin="5" 
                        ToolTip="Spielfeld"
                        Click="BtnGameBoard_Click">
                    <TextBlock Text="🎮" FontSize="24"/>
                </Button>

            </StackPanel>
        </Border>

        <!-- Hauptinhalt mit innerem Rahmen -->
        <Border Grid.Row="1" Grid.Column="1" 
                Margin="10" 
                BorderBrush="{StaticResource PrimaryBrush}" 
                BorderThickness="2" 
                CornerRadius="8"
                Background="{StaticResource PrimaryBrush}">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Margin="5"/>
        </Border>

        <!-- Untere Leiste mit Zierrahmen -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,3,0,0"
                Effect="{StaticResource BottomPanelShadow}">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                
                <!-- Buttons mit umgebenden Rahmen -->
                <Border BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Margin="5" 
                        Padding="2">
                    <Button x:Name="BtnStart" 
                            Content="▶ Start" 
                            Style="{StaticResource MenuButtonStyle}"
                            Width="90" Height="30"
                            FontSize="13"
                            Click="BtnStart_Click"/>
                </Border>
                
                <Border BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Margin="5" 
                        Padding="2">
                    <Button x:Name="BtnReset" 
                            Content="🔄 Reset" 
                            Style="{StaticResource MenuButtonStyle}"
                            Width="90" Height="30"
                            FontSize="13"
                            Click="BtnReset_Click"/>
                </Border>
                
                <Border BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Margin="5" 
                        Padding="2">
                    <Button x:Name="BtnStep" 
                            Content="⏭ Step" 
                            Style="{StaticResource MenuButtonStyle}"
                            Width="90" Height="30"
                            FontSize="13"
                            Click="BtnStep_Click"/>
                </Border>
                
            </StackPanel>
        </Border>
    </Grid>
</Window>

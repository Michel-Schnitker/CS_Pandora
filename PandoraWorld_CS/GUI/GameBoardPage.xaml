<Page x:Class="PandoraWorld_CS.GUI.GameBoardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GameBoardPage">

    <Grid Background="{StaticResource PrimaryBrush}">
        <!-- Zeilen-Definition fuer Header, Board und Footer -->
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>  <!-- Header/Toolbar -->
            <RowDefinition Height="*"/>     <!-- Board (fuellt restlichen Platz) -->
            <RowDefinition Height="20"/>  <!-- Footer/Statusleiste -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="10">
            <!-- Header -->
        </StackPanel>
        
        <Border Grid.Row="1" 
                Grid.Column="1"
                Margin="5" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="3"
                CornerRadius="8"
                Background="{StaticResource PrimaryBrush}"
                Effect="{StaticResource BoardShadow}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" 
                          VerticalScrollBarVisibility="Disabled">
                <UniformGrid x:Name="BoardGrid" />
            </ScrollViewer>
        </Border>
        
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="10">
            <!-- Footer -->
        </StackPanel>
    </Grid>
</Page>